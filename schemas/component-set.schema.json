{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Component Set",
  "description": "A component set in the Lumavate platform",
  "type": "object",
  "properties": {
    "components": {
      "description": "The component definitions for this component set",
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string"
          },
          "icon": {
            "type": "string",
            "pattern": "\\.svg$"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "type": {
            "type": "string",
            "$comment": "Type must be numeric, lower case letters and/or dashes",
            "pattern": "^[0-9a-z\\-]+$"
          },
          "properties": {
            "description": "The properties for the component",
            "type": "array",
            "items": {
              "$comment": "The $id here tells the schema to search that schema for any $ref properties",
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "enum": [
                    "theme-color",
                    "code-editor",
                    "translated-text",
                    "text",
                    "color",
                    "image-upload",
                    "checkbox",
                    "toggle",
                    "dropdown",
                    "numeric",
                    "multiselect",
                    "page-link"
                  ]
                }
              },
              "allOf": [
                {
                  "if": {
                    "properties": {
                      "type": {
                        "const": "text"
                      }
                    }
                  },
                  "then": {
                    "allOf": [
                      {
                        "$ref": "#/definitions/text"
                      }
                    ]
                  }
                },
                {
                  "if": {
                    "properties": {
                      "type": {
                        "const": "numeric"
                      }
                    }
                  },
                  "then": {
                    "allOf": [
                      {
                        "$ref": "#/definitions/numeric"
                      }
                    ]
                  }
                },
                {
                  "if": {
                    "properties": {
                      "type": {
                        "const": "translated-text"
                      }
                    }
                  },
                  "then": {
                    "allOf": [
                      {
                        "$ref": "#/definitions/translatedText"
                      }
                    ]
                  }
                },
                {
                  "if": {
                    "properties": {
                      "type": {
                        "const": "theme-color"
                      }
                    }
                  },
                  "then": {
                    "allOf": [
                      {
                        "$ref": "#/definitions/themeColor"
                      }
                    ]
                  }
                },
                {
                  "if": {
                    "properties": {
                      "type": {
                        "const": "code-editor"
                      }
                    }
                  },
                  "then": {
                    "allOf": [
                      {
                        "$ref": "#/definitions/codeEditor"
                      }
                    ]
                  }
                },
                {
                  "if": {
                    "properties": {
                      "type": {
                        "const": "checkbox"
                      }
                    }
                  },
                  "then": {
                    "allOf": [
                      {
                        "$ref": "#/definitions/checkbox"
                      }
                    ]
                  }
                },
                {
                  "if": {
                    "properties": {
                      "type": {
                        "const": "color"
                      }
                    }
                  },
                  "then": {
                    "allOf": [
                      {
                        "$ref": "#/definitions/color"
                      }
                    ]
                  }
                },
                {
                  "if": {
                    "properties": {
                      "type": {
                        "const": "dropdown"
                      }
                    }
                  },
                  "then": {
                    "allOf": [
                      {
                        "$ref": "#/definitions/dropdown"
                      }
                    ]
                  }
                },
                {
                  "if": {
                    "properties": {
                      "type": {
                        "const": "image-upload"
                      }
                    }
                  },
                  "then": {
                    "allOf": [
                      {
                        "$ref": "#/definitions/imageUpload"
                      }
                    ]
                  }
                },
                {
                  "if": {
                    "properties": {
                      "type": {
                        "const": "multiselect"
                      }
                    }
                  },
                  "then": {
                    "allOf": [
                      {
                        "$ref": "#/definitions/multiselect"
                      }
                    ]
                  }
                },
                {
                  "if": {
                    "properties": {
                      "type": {
                        "const": "page-link"
                      }
                    }
                  },
                  "then": {
                    "allOf": [
                      {
                        "$ref": "#/definitions/pageLink"
                      }
                    ]
                  }
                },
                {
                  "if": {
                    "properties": {
                      "type": {
                        "const": "toggle"
                      }
                    }
                  },
                  "then": {
                    "allOf": [
                      {
                        "$ref": "#/definitions/toggle"
                      }
                    ]
                  }
                }
              ],
              "required": [
                "type"
              ]
            },
            "minItems": 1
          },
          "displayNameTemplate": {
            "type": "string"
          },
          "template": {
            "oneOf": [
              {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "minItems": 1
              },
              {
                "type": "string"
              }
            ]
          }
        },
        "required": [
          "label",
          "section",
          "icon",
          "tags",
          "type",
          "properties",
          "template"
        ]
      }
    },
    "styleData": {
      "type": "array",
      "items": {
        "$comment": "The $id here tells the schema to search that schema for any $ref properties",
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "text",
              "color"
            ]
          },
          "value": {
            "type": "string"
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "type": {
                  "const": "text"
                }
              }
            },
            "then": {
              "allOf": [
                {
                  "$ref": "#/definitions/text"
                }
              ]
            }
          },
          {
            "if": {
              "properties": {
                "type": {
                  "const": "color"
                }
              }
            },
            "then": {
              "allOf": [
                {
                  "$ref": "#/definitions/color"
                }
              ]
            }
          }
        ],
        "required": [
          "name",
          "value",
          "type"
        ]
      },
      "minItems": 0
    }
  },
  "required": [
    "components",
    "styleData"
  ],
  "definitions": {
    "common": {
      "properties": {
        "classification": {
          "type": [
            "string",
            "null"
          ]
        },
        "section": {
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "type": "string",
          "$comment": "Name must be lower camel case",
          "pattern": "^[a-z]+[A-Za-z0-9]*$"
        },
        "label": {
          "type": "string"
        },
        "helpText": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "name",
        "label"
      ]
    },
    "text": {
      "allOf": [
        {
          "$ref": "#/definitions/common"
        },
        {
          "properties": {
            "default": {
              "type": "string"
            },
            "options": {
              "type": "object",
              "properties": {
                "readonly": {
                  "oneOf": [
                    {
                      "type": "string",
                      "$comment": "Allow case insensitive true|false string",
                      "pattern": "^(?i)(true|false)$"
                    },
                    {
                      "type": "boolean"
                    }
                  ]
                },
                "rows": {
                  "type": "integer",
                  "minimum": 1
                }
              }
            }
          }
        }
      ]
    },
    "translatedText": {
      "allOf": [
        {
          "$ref": "#/definitions/common"
        },
        {
          "properties": {
            "default": {
              "type": "object",
              "$comment": "Allow any text as the key for a language",
              "patternProperties": {
                ".*": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            },
            "options": {
              "type": "object",
              "properties": {
                "readonly": {
                  "oneOf": [
                    {
                      "type": "string",
                      "$comment": "Allow case insensitive true or false string",
                      "pattern": "^(?i)(true|false)$"
                    },
                    {
                      "type": "boolean"
                    }
                  ]
                },
                "rows": {
                  "type": "integer",
                  "minimum": 1
                }
              }
            }
          }
        }
      ]
    },
    "numeric": {
      "allOf": [
        {
          "$ref": "#/definitions/common"
        },
        {
          "properties": {
            "default": {
              "type": "number"
            },
            "options": {
              "type": "object",
              "properties": {
                "min": {
                  "type": "integer"
                },
                "max": {
                  "type": "integer"
                }
              }
            }
          }
        }
      ]
    },
    "themeColor": {
      "allOf": [
        {
          "$ref": "#/definitions/common"
        },
        {
          "properties": {
            "default": {
              "type": "string"
            }
          }
        }
      ]
    },
    "codeEditor": {
      "allOf": [
        {
          "$ref": "#/definitions/common"
        },
        {
          "properties": {
            "default": {
              "type": "string"
            }
          }
        }
      ]
    },
    "checkbox": {
      "allOf": [
        {
          "$ref": "#/definitions/common"
        },
        {
          "properties": {
            "default": {
              "oneOf": [
                {
                  "type": "string",
                  "$comment": "Allow case insensitive true or false string",
                  "pattern": "^(?i)(true|false)$"
                },
                {
                  "type": "boolean"
                }
              ]
            }
          }
        }
      ]
    },
    "color": {
      "allOf": [
        {
          "$ref": "#/definitions/common"
        },
        {
          "properties": {
            "default": {
              "type": "string"
            }
          }
        }
      ]
    },
    "dropdown": {
      "allOf": [
        {
          "$ref": "#/definitions/common"
        },
        {
          "properties": {
            "default": {
              "type": "string"
            },
            "options": {
              "type": "object",
              "patternProperties": {
                ".*": {
                  "type": "string"
                }
              },
              "additionalProperties": false,
              "minProperties": 1
            }
          },
          "required": [
            "options"
          ]
        }
      ]
    },
    "imageUpload": {
      "allOf": [
        {
          "$ref": "#/definitions/common"
        },
        {
          "properties": {
            "default": {
              "oneOf": [
                {
                  "type": "null"
                },
                {
                  "type": "object",
                  "properties": {
                    "ephemeralKey": {
                      "type": "string"
                    },
                    "previewMedium": {
                      "type": "string"
                    },
                    "thumbnail": {
                      "type": "string"
                    }
                  }
                }
              ]
            }
          }
        }
      ]
    },
    "multiselect": {
      "allOf": [
        {
          "$ref": "#/definitions/common"
        },
        {
          "properties": {
            "default": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1
            },
            "options": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "displayValue": {
                    "type": "string"
                  },
                  "value": {
                    "type": "string"
                  }
                }
              },
              "minItems": 1
            }
          },
          "required": [
            "options"
          ]
        }
      ]
    },
    "pageLink": {
      "allOf": [
        {
          "$ref": "#/definitions/common"
        },
        {
          "properties": {
            "default": {
              "type": "object",
              "properties": {
                "mode": {
                  "type": "string"
                },
                "instanceId": {
                  "type": "number"
                },
                "url": {
                  "type": "string"
                }
              }
            }
          }
        }
      ]
    },
    "toggle": {
      "allOf": [
        {
          "$ref": "#/definitions/common"
        },
        {
          "properties": {
            "default": {
              "oneOf": [
                {
                  "type": "string",
                  "$comment": "Allow case insensitive true or false string",
                  "pattern": "^(?i)(true|false)$"
                },
                {
                  "type": "boolean"
                }
              ]
            }
          }
        }
      ]
    }
  }
}
